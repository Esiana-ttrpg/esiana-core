{
  "name": "@esiana/plugin-source-policy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Plugin remote source host allowlist for Esiana",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@esiana/ssrf-guard": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
