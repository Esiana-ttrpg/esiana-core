# See prisma/README.md — set provider literal in schema.prisma (postgresql | sqlite)
DATABASE_URL="postgresql://esiana:esiana@localhost:5432/esiana"
DATABASE_PROVIDER=postgresql

PORT=3001
NODE_ENV=development

# JWT (use a long random string in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_NAME=esiana_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Reverse proxy (set true when behind nginx/caddy so rate limits use client IP)
TRUST_PROXY=false

# Rate limits (optional — defaults are lenient for small self-hosted instances)
# RATE_LIMIT_LOGIN_MAX=20
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_EMAIL_MAX=30
# RATE_LIMIT_APPLY_CAMPAIGN_MAX=10

# Paths (relative to repo root)
UPLOADS_DIR=../uploads
PLUGINS_DIR=../plugins

# Storage (Phase 10A — provider-agnostic registry)
STORAGE_PROVIDER=filesystem
STORAGE_REDIRECT_THRESHOLD_BYTES=5242880

# Plugin runtime interceptors (Phase 10C)
PLUGIN_INTERCEPTOR_TIMEOUT_MS=200
PLUGIN_MAX_HOOKS_PER_PLUGIN=10
PLUGIN_MAX_CONCURRENT_INTERCEPTORS=4

# Campaign generator demo accounts (seeded @seed.esiana.local logins)
# ENABLE_DEMO_USERS=true

# Core Sample Data profiles (dev fixtures — does not gate Content Packs)
# ENABLE_SAMPLE_DATA=true

# Cartography pipeline
MAP_PRESERVE_FULL_RES=false
MAP_DISPLAY_MAX_EDGE=8192
MAP_THUMB_MAX_EDGE=2048
