# Postgres + Docker Compose environment
# Copy to .env in esiana-core root for: docker compose up -d --build

POSTGRES_USER=esiana
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=esiana

DATABASE_URL=postgresql://esiana:change-me-in-production@postgres:5432/esiana
JWT_SECRET=change-me-use-openssl-rand-base64-32
AUTH_SECRETS_KEY=
FRONTEND_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost:8080
NODE_ENV=production
OPENAPI_DOCS_ENABLED=true
