{
  "id": "example-plugin",
  "name": "Example Plugin",
  "version": "1.1.0",
  "description": "Reference plugin demonstrating Pre-1.0 platform APIs.",
  "scope": "global",
  "category": "utility",
  "engines": { "esiana-core": "^0.8.0" },
  "permissions": [
    "plugin:data",
    "data:interceptor",
    "ui:slot",
    "campaign:read-calendar",
    "plugin:config",
    "campaign:import"
  ],
  "uiSlots": ["sidebar", "header", "dashboard", "campaign-plugin-settings"],
  "uninstallPolicy": "removePluginData",
  "configSchema": {
    "type": "object",
    "properties": {
      "greeting": {
        "type": "string",
        "title": "Greeting message",
        "default": "Hello from example-plugin"
      }
    }
  },
  "configTemplate": [
    {
      "key": "greeting",
      "label": "Greeting message",
      "type": "text",
      "defaultValue": "Hello from example-plugin"
    }
  ],
  "githubUrl": "https://github.com/Esiana-ttrpg/community-plugins/tree/main/example-plugin",
  "backendEntry": "backend/index.js",
  "frontendEntry": "frontend/index.js"
}
