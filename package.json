    "plugins:link": "node scripts/link-community-plugins.mjs",
    "seed-campaign": "pnpm --filter backend seed-campaign",
    "profile-capacity": "pnpm --filter backend profile-capacity"
  },
  "engines": {
    "node": ">=20.0.0"
  }
